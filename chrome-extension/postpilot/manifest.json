{
  "manifest_version": 3,
  "name": "Post Pilot Assist",
  "version": "0.2.2",
  "minimum_chrome_version": "116",
  "description": "Auto-post helper for Post Pilot Facebook personal and Threads drafts from BuddyPilot.",
  "permissions": ["storage", "tabs", "alarms", "clipboardWrite", "unlimitedStorage"],
  "host_permissions": [
    "https://www.facebook.com/*",
    "https://facebook.com/*",
    "https://www.threads.com/*",
    "https://threads.com/*",
    "https://www.threads.net/*",
    "https://threads.net/*",
    "https://buddypilot.vercel.app/*",
    "https://*.supabase.co/*",
    "wss://*.supabase.co/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Post Pilot",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://buddypilot.vercel.app/*", "http://localhost/*", "http://127.0.0.1/*"],
      "js": ["webapp-content.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://www.facebook.com/*", "https://facebook.com/*"],
      "js": ["facebook-content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.threads.com/*", "https://threads.com/*", "https://www.threads.net/*", "https://threads.net/*"],
      "js": ["threads-content.js"],
      "run_at": "document_idle"
    }
  ]
}
