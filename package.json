{
  "name": "buddy-pilot",
  "version": "1.0.0",
  "private": true,
  "description": "Manage business workflows, creatives, reports, invoices, and receipts in one app.",
  "scripts": {
    "check": "find api api_handlers lib scripts -name '*.js' -print0 | xargs -0 -n1 node --check",
    "test": "node --test",
    "ip": "node scripts/invoice-pilot-cli.js",
    "supabase:setup": "node scripts/setup-supabase.js",
    "supabase:migrate-drive": "node scripts/migrate-drive-to-supabase.js",
    "vercel:repair": "node scripts/invoice-pilot-cli.js repair",
    "vercel:deploy": "node scripts/invoice-pilot-cli.js deploy"
  },
  "dependencies": {
    "@modelcontextprotocol/client": "2.0.0-beta.5",
    "googleapis": "^173.0.0",
    "pdfkit": "^0.15.0",
    "web-push": "3.6.7"
  },
  "engines": {
    "node": ">=20"
  }
}
