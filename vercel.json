{
  "routes": [
    {
      "src": "/",
      "dest": "/api/app"
    },
    {
      "src": "/login",
      "dest": "/api/login-page"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "functions": {
    "api/post.js": {
      "maxDuration": 60
    },
    "api/preview.js": {
      "maxDuration": 30
    },
    "api/regenerate.js": {
      "maxDuration": 30
    }
  }
}
